   2:main_cm4.c    **** 
   3:main_cm4.c    **** /*============================================================================
   4:main_cm4.c    ****  * KnockLock — PSoC 6 / PSoC Creator 4.4
   5:main_cm4.c    ****  *
   6:main_cm4.c    ****  * Hardware
   7:main_cm4.c    ****  *   - MG996R servo motor          → PWM_Servo component
   8:main_cm4.c    ****  *   - LIS3DH accelerometer        → SensorBus (I2C) component
   9:main_cm4.c    ****  *   - Adafruit 4x4 matrix keypad  → GPIO (Port 10 / Port 5)
  10:main_cm4.c    ****  *   - Status LED                  → LED component (active-low GPIO)
  11:main_cm4.c    ****  *   - UART terminal               → UART component
  12:main_cm4.c    ****  *   - Push button                 → BUTTON GPIO pin (active-low, falling edge)
  13:main_cm4.c    ****  *
  14:main_cm4.c    ****  * Lock flow
  15:main_cm4.c    ****  *   1. User enters PIN on keypad and presses '#'.
  16:main_cm4.c    ****  *   2. If PIN matches, LED blinks to prompt knock sequence.
  17:main_cm4.c    ****  *   3. Accelerometer detects knocks; inter-knock intervals are recorded.
  18:main_cm4.c    ****  *   4. If knock pattern matches, servo moves to UNLOCK position.
  19:main_cm4.c    ****  *   5. Lock STAYS UNLOCKED until:
  20:main_cm4.c    ****  *        a. Button press  → toggles lock state
  21:main_cm4.c    ****  *        b. '*' on keypad → locks immediately
  22:main_cm4.c    ****  *============================================================================*/
  23:main_cm4.c    **** 
  24:main_cm4.c    **** #include "project.h"
  25:main_cm4.c    **** #include <stdlib.h>
  26:main_cm4.c    **** #include <string.h>
  27:main_cm4.c    **** #include <stdio.h>
  28:main_cm4.c    **** #include <stdint.h>
  29:main_cm4.c    **** #include <stdbool.h>
  30:main_cm4.c    **** #include <math.h>      /* sqrtf */
ARM GAS  C:\Users\iyung\AppData\Local\Temp\cc2jnA4D.s 			page 2


