  71:main_cm4.c    ****     {'7','8','9','C'},
  72:main_cm4.c    ****     {'*','0','#','D'}
  73:main_cm4.c    **** };
  74:main_cm4.c    **** 
  75:main_cm4.c    **** /* Knock detection */
  76:main_cm4.c    **** #define KNOCK_THRESHOLD        10.0f   /* m/s² spike needed to register knock */
  77:main_cm4.c    **** #define KNOCK_DEBOUNCE_MS      200    /* minimum ms before next knock         */
  78:main_cm4.c    **** #define TARGET_DELAY_MS        1000   /* target inter-knock gap (ms)          */
  79:main_cm4.c    **** #define TOLERANCE_MS           500    /* ± ms human timing tolerance          */
  80:main_cm4.c    **** 
  81:main_cm4.c    **** /* Knock state machine states */
  82:main_cm4.c    **** #define STATE_LOCKED_WAIT_K1   0
  83:main_cm4.c    **** #define STATE_LOCKED_WAIT_K2   1
  84:main_cm4.c    **** #define STATE_UNLOCKED         2
  85:main_cm4.c    **** 
  86:main_cm4.c    **** /* PIN entry inactivity timeout */
  87:main_cm4.c    **** #define PIN_TIMEOUT_MS         10000u /* 20 seconds of no keypresses → sleep  */
