  60:main_cm4.c    **** #define COL0_PIN    6u
  61:main_cm4.c    **** #define COL1_PORT   GPIO_PRT10
  62:main_cm4.c    **** #define COL1_PIN    5u
  63:main_cm4.c    **** #define COL2_PORT   GPIO_PRT10
  64:main_cm4.c    **** #define COL2_PIN    4u
  65:main_cm4.c    **** #define COL3_PORT   GPIO_PRT10
  66:main_cm4.c    **** #define COL3_PIN    3u
  67:main_cm4.c    **** 
