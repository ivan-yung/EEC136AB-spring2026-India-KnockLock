  51:main_cm4.c    **** #define ROW0_PIN    2u
  52:main_cm4.c    **** #define ROW1_PORT   GPIO_PRT10
  53:main_cm4.c    **** #define ROW1_PIN    1u
  54:main_cm4.c    **** #define ROW2_PORT   GPIO_PRT10
  55:main_cm4.c    **** #define ROW2_PIN    0u
  56:main_cm4.c    **** #define ROW3_PORT   GPIO_PRT5
  57:main_cm4.c    **** #define ROW3_PIN    6u
  58:main_cm4.c    **** /* Column pins */
