  41:main_cm4.c    **** #define MAX_PULSE_WIDTH     2400u       /* µs — 180 °                      */
  42:main_cm4.c    **** #define SERVO_MAX_DEG       180u
  43:main_cm4.c    **** #define SERVO_LOCK_DEG      45u  // good: 135u
  44:main_cm4.c    **** #define SERVO_UNLOCK_DEG    135u   // good: 45u
  45:main_cm4.c    **** 
  46:main_cm4.c    **** /*---------------------------------------------------------------------------
  47:main_cm4.c    ****  * Keypad (Adafruit 4×4) pin mapping
  48:main_cm4.c    ****  *---------------------------------------------------------------------------*/
  49:main_cm4.c    **** /* Row pins */
